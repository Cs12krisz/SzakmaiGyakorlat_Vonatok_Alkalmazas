<Window x:Class="VonatokWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VonatokWPF"
        mc:Ignorable="d"
        Title="Vonatok várakozása" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <StackPanel>
            <Label Content="Vonalszám:"></Label>
            <ComboBox x:Name="cbxVonalSzam" SelectionChanged="cbxVonalSzam_SelectionChanged" />
            <Button Content="Mentés"/>
        </StackPanel>
        <TextBlock x:Name="txblAdatok" Grid.Column="1" Text="Kérem válasszon vonalszámot!"></TextBlock>

    </Grid>
</Window>
